generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique

  email     String   @unique
  name      String?

  createdAt DateTime @default(now())

  vouchers  Voucher[]
}

model Voucher {
  id          String   @id @default(cuid())

  title       String
  description String?

  category    String

  expiryDate  DateTime

  createdAt   DateTime @default(now())

  userId      String
  user        User @relation(fields: [userId], references: [id])
}
